p50[1:50] = 1
plot(tiempo, p50, type ='l')
# La transf de fourier de p1
fft.p1 = fft(p1)
plot(Mod(fft.p1), type = 'l')
# Conclusion: Un impulso en un dominio del tiempo = todas las freq en un
# valor constante
# Osea un impulso contiene todas las frecuencias
