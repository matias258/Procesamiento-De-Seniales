lines(dato$t, outMA21, col='red')   # Tendencia / Baja frecuencia
lines(dato$t, difMA21, col='green') # Estacionalidad / Frecuencia intermedia
# Transformada de Fourier (FFT) y cálculo del Módulo (Magnitud)
