# 1. Definimos los datos (0 a 260 días)
t_vals <- 0:260
set.seed(123)
df_completo <- data.frame(
X = 1:261,
t = t_vals,
a0 = 10 + 0.03 * t_vals,                     # Tendencia
a1 = 4 * sin(2 * pi * t_vals / 20),          # Estacionalidad rápida
a2 = 2 * cos(2 * pi * t_vals / 100),         # Estacionalidad lenta
rn = rnorm(261, 0, 0.8)                      # Ruido
)
# 2. Sumamos las componentes para crear la señal 'a'
df_completo$a <- df_completo$a0 + df_completo$a1 + df_completo$a2 + df_completo$rn
# 3. Definimos la ruta de guardado (Usamos "/" para evitar errores en R)
ruta_destino <- "/Desktop/Procesamiento-De-Seniales/Teoría/TS_1.csv"
# 4. Guardamos el archivo
write.csv(df_completo, ruta_destino, row.names = FALSE)
