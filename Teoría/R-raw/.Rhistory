# Filtro de Hanning de 3 puntos
fir3      <- rep(0, N)
fir3[1]   <- 1/4
fir3[2]   <- 1/2
fir3[3]   <- 1/4
# Filtro de media móvil de 3 puntos
ma3       <- rep(0, N)
ma3[1:3]  <- 1/3
